# Copy to .env and fill in values from Firebase + Supabase dashboards.
# Never commit .env to git.

EXPO_PUBLIC_SUPABASE_URL=https://pnmnfxnkqsbgsixtkggy.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_DrMISXDeTSBoblo68e8TSQ_HCxEETjZ

# One-time database migrations:
#   npm run db:migrate-farm-profile
#   npm run db:migrate-fields-scans
#   npm run db:migrate-scan-video
#
# Option A — add your Database URI to .env (pick one format):
#
# Direct connection (easiest for migrations):
# SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pnmnfxnkqsbgsixtkggy.supabase.co:5432/postgres
#
# Session pooler (port must be 6543):
# SUPABASE_DB_URL=postgresql://postgres.pnmnfxnkqsbgsixtkggy:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres
#
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# If password has special characters (@ # / %), URL-encode them (e.g. @ → %40)
#
# Option B — Management API token instead:
# SUPABASE_ACCESS_TOKEN=sbp_... from https://supabase.com/dashboard/account/tokens

# Web Firebase SDK (Project settings → Your apps → Web app, or `firebase apps:sdkconfig WEB`)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Phase 3 — scan analysis API (FastAPI backend in /backend)
# Local dev: use your machine's LAN IP when testing on a physical device (not localhost)
# EXPO_PUBLIC_ANALYSIS_API_URL=http://192.168.1.42:8000
#
# Production (Vercel web + hosted backend on Railway/Render/Fly):
# EXPO_PUBLIC_ANALYSIS_API_URL=https://your-analysis-api.example.com
# Optional dev key — must match THERA_ANALYSIS_API_KEY in backend/.env
# EXPO_PUBLIC_ANALYSIS_API_KEY=dev-only-key

# Push notifications (Expo Push Service) — run: npx eas init
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-uuid