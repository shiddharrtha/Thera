{
  "expo": {
    "name": "Thera",
    "slug": "Thera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#EEF1EE",
    "splash": {
      "backgroundColor": "#1B6B38"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thera.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Thera uses the camera to record field scans while you walk crop rows.",
        "NSMicrophoneUsageDescription": "Thera records audio with field scan videos.",
        "NSLocationWhenInUseUsageDescription": "Thera tracks your location during scans to map weeds and crop stress to your field.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.thera.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Thera to scan your fields with the camera.",
          "microphonePermission": "Allow Thera to record audio during field scans.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Thera to track scan location for field mapping."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Gilroy-ExtraBold.ttf"
          ]
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth"
            ]
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ]
  }
}
