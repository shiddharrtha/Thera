# Copy to backend/.env and fill in values.

# Server
THERA_HOST=0.0.0.0
THERA_PORT=8000
THERA_CORS_ORIGINS=*

# Supabase — secret key lets the backend download private scan videos
# Use the base project URL (no /rest/v1 suffix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Firebase — verify mobile ID tokens (download service account JSON from Firebase console)
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Optional dev bypass when Firebase admin is not configured (never use in production)
THERA_ANALYSIS_API_KEY=dev-only-key

# Analysis tuning
THERA_MAX_FRAMES=24
THERA_FRAME_INTERVAL_SEC=2.0
# Optional custom YOLO weights for weed/crop classes (.pt file)
# THERA_YOLO_WEIGHTS=./models/weed_yolo.pt
