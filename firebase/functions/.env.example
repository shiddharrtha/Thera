# Firebase Console → Functions → Environment variables (or: firebase functions:config:set)

# Option A — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Thera <noreply@yourdomain.com>

# Option B — SMTP (e.g. Gmail app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=Thera <you@gmail.com>

# Development only — returns OTP in API response when email is not configured
# THERA_EXPOSE_OTP=true
